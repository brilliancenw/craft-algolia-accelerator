{% import '_includes/forms.twig' as forms %}

{% set isReady = isConfigured and workerStatus.online %}

<div class="algolia-cache-utility">

    {# Setup Required - show prominently if not configured #}
    {% if not isConfigured %}
    <div class="readable" style="margin-bottom: 24px;">
        <blockquote class="note warning">
            <p><strong>{{ 'Setup Required'|t('algolia-accelerator') }}</strong></p>
            <p>{{ "Your domain's DNS must be routed through Cloudflare, and a Cloudflare Worker must be deployed."|t('algolia-accelerator') }}</p>
            <p style="margin-top: 12px;">{{ 'The plugin settings page includes step-by-step instructions for setting up the Worker through the Cloudflare Dashboard (no CLI required).'|t('algolia-accelerator') }}</p>
            <p style="margin-top: 12px;">
                <a href="{{ cpUrl('settings/plugins/algolia-accelerator') }}" class="btn submit">{{ 'Open Settings & Setup Guide'|t('algolia-accelerator') }}</a>
            </p>
        </blockquote>
    </div>
    {% endif %}

    {# Status Section #}
    <h2>{{ 'Status'|t('algolia-accelerator') }}</h2>

    {# Configuration Status #}
    <div class="field">
        <div class="heading">
            <label>{{ 'Configuration'|t('algolia-accelerator') }}</label>
        </div>
        <div class="input">
            {% if isConfigured %}
                <span class="status green"></span>
                <span>{{ 'Configured'|t('algolia-accelerator') }}</span>
                <span class="light"> - <a href="{{ cpUrl('settings/plugins/algolia-accelerator') }}">{{ 'Edit settings'|t('algolia-accelerator') }}</a></span>
            {% else %}
                <span class="status red"></span>
                <span>{{ 'Not configured'|t('algolia-accelerator') }}</span>
                <span class="light"> - <a href="{{ cpUrl('settings/plugins/algolia-accelerator') }}">{{ 'Configure worker host and purge token'|t('algolia-accelerator') }}</a></span>
            {% endif %}
        </div>
    </div>

    {# Worker Status #}
    <div class="field">
        <div class="heading">
            <label>{{ 'Worker Status'|t('algolia-accelerator') }}</label>
        </div>
        <div class="input">
            {% if workerStatus.online %}
                <span class="status green"></span>
                <span>{{ 'Online'|t('algolia-accelerator') }}</span>
                {% if workerStatus.data.environment is defined %}
                    <span class="light"> ({{ workerStatus.data.environment }})</span>
                {% endif %}
            {% else %}
                <span class="status red"></span>
                <span>{{ 'Offline'|t('algolia-accelerator') }}</span>
                {% if not isConfigured %}
                    <span class="light"> - {{ 'Configure settings first'|t('algolia-accelerator') }}</span>
                {% else %}
                    <span class="light"> - {{ workerStatus.message }}</span>
                {% endif %}
            {% endif %}
        </div>
    </div>

    {# Trigger Sections #}
    <div class="field">
        <div class="heading">
            <label>{{ 'Trigger Sections'|t('algolia-accelerator') }}</label>
        </div>
        <div class="input">
            {% if triggerSectionNames|length %}
                {{ triggerSectionNames|join(', ') }}
            {% else %}
                <span class="light">{{ 'No sections configured'|t('algolia-accelerator') }} - <a href="{{ cpUrl('settings/plugins/algolia-accelerator') }}">{{ 'Edit settings'|t('algolia-accelerator') }}</a></span>
            {% endif %}
        </div>
    </div>

    <hr>

    {# Enable/Disable Toggle - only show when ready #}
    <h2>{{ 'Cache Purging'|t('algolia-accelerator') }}</h2>

    {% if isReady %}
        {{ forms.lightswitchField({
            label: 'Auto-Purge on Entry Save'|t('algolia-accelerator'),
            instructions: 'When enabled, the cache will automatically purge when entries in the configured sections are saved. When disabled, cache will only expire based on TTL.'|t('algolia-accelerator'),
            id: 'accelerator-toggle',
            name: 'enabled',
            on: settings.enabled,
        }) }}
    {% else %}
        <div class="field">
            <div class="heading">
                <label>{{ 'Auto-Purge on Entry Save'|t('algolia-accelerator') }}</label>
            </div>
            <div class="input">
                <span class="light">
                    {% if not isConfigured %}
                        {{ 'Configure settings before enabling.'|t('algolia-accelerator') }}
                    {% elseif not workerStatus.online %}
                        {{ 'Worker must be online before enabling.'|t('algolia-accelerator') }}
                    {% endif %}
                </span>
            </div>
        </div>
    {% endif %}

    {# Last Purge #}
    <div class="field">
        <div class="heading">
            <label>{{ 'Last Purge (this session)'|t('algolia-accelerator') }}</label>
        </div>
        <div class="input" id="lastPurgeTime">
            {% if lastPurgeTime %}
                {{ lastPurgeTime }}
            {% else %}
                <span class="light">{{ 'Not purged yet'|t('algolia-accelerator') }}</span>
            {% endif %}
        </div>
    </div>

    {# Manual Purge Button #}
    <div class="field">
        <div class="heading">
            <label>{{ 'Manual Purge'|t('algolia-accelerator') }}</label>
            <div class="instructions">
                <p>{{ 'Immediately purge all cached search results. This will cause the next search requests to fetch fresh data from Algolia.'|t('algolia-accelerator') }}</p>
            </div>
        </div>
        <div class="input">
            <button type="button" id="purge-cache-btn" class="btn {% if not isReady %}disabled{% endif %}" {% if not isReady %}disabled{% endif %}>
                {{ 'Purge Cache'|t('algolia-accelerator') }}
            </button>
            <span id="purge-status" class="light" style="margin-left: 10px;"></span>
        </div>
    </div>

    {# Refresh Status Button #}
    <div class="field">
        <div class="input">
            <button type="button" id="refresh-status-btn" class="btn secondary">
                {{ 'Refresh Status'|t('algolia-accelerator') }}
            </button>
        </div>
    </div>

    <hr>

    {# Troubleshooting Section #}
    <h2>{{ 'Troubleshooting'|t('algolia-accelerator') }}</h2>

    <div class="readable">
        <h4 style="margin-top: 0;">{{ 'Checking Cache Status (HIT vs MISS)'|t('algolia-accelerator') }}</h4>
        <p>{{ 'The Cloudflare Worker adds response headers to every search request that tell you whether the response came from cache:'|t('algolia-accelerator') }}</p>

        <table class="data" style="margin: 16px 0;">
            <thead>
                <tr>
                    <th>{{ 'Header'|t('algolia-accelerator') }}</th>
                    <th>{{ 'Description'|t('algolia-accelerator') }}</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td><code>X-Cache: HIT</code></td>
                    <td>{{ 'Response was served from cache (fast, typically 2-10ms)'|t('algolia-accelerator') }}</td>
                </tr>
                <tr>
                    <td><code>X-Cache: MISS</code></td>
                    <td>{{ 'Response was fetched from Algolia and then cached (slower, typically 300-500ms)'|t('algolia-accelerator') }}</td>
                </tr>
                <tr>
                    <td><code>X-Response-Time</code></td>
                    <td>{{ 'How long the request took (e.g., "5ms" or "350ms")'|t('algolia-accelerator') }}</td>
                </tr>
                <tr>
                    <td><code>X-Cache-Key</code></td>
                    <td>{{ 'The unique cache key for this request (useful for debugging)'|t('algolia-accelerator') }}</td>
                </tr>
            </tbody>
        </table>

        <h4>{{ 'How to View Response Headers'|t('algolia-accelerator') }}</h4>
        <ol>
            <li>{{ 'Open your browser Developer Tools (F12 or right-click → Inspect)'|t('algolia-accelerator') }}</li>
            <li>{{ 'Go to the <strong>Network</strong> tab'|t('algolia-accelerator')|raw }}</li>
            <li>{{ 'Perform a search on your site'|t('algolia-accelerator') }}</li>
            <li>{{ 'Look for requests to your worker domain (e.g., search-api.yourdomain.com)'|t('algolia-accelerator') }}</li>
            <li>{{ 'Click the request and view the <strong>Response Headers</strong> section'|t('algolia-accelerator')|raw }}</li>
        </ol>

        <h4>{{ 'Common Issues'|t('algolia-accelerator') }}</h4>
        <dl>
            <dt><strong>{{ 'Always seeing MISS'|t('algolia-accelerator') }}</strong></dt>
            <dd>{{ 'Each unique search query creates a separate cache entry. Identical searches should show HIT on the second request. If not, check that your KV namespace is properly bound in Cloudflare Worker settings.'|t('algolia-accelerator') }}</dd>

            <dt style="margin-top: 12px;"><strong>{{ 'Cache not purging when content is saved'|t('algolia-accelerator') }}</strong></dt>
            <dd>{{ "Check that the entry's section is selected in Trigger Sections (plugin settings), and verify the Worker Host and Purge Token are correct."|t('algolia-accelerator') }}</dd>

            <dt style="margin-top: 12px;"><strong>{{ 'Worker status showing Offline'|t('algolia-accelerator') }}</strong></dt>
            <dd>{{ 'Verify your Worker is deployed in Cloudflare and the Worker Host URL is correct. Try visiting'|t('algolia-accelerator') }} <code>https://[your-worker-host]/health</code> {{ 'directly in your browser.'|t('algolia-accelerator') }}</dd>
        </dl>
    </div>
</div>

{% js %}
(function() {
    const purgeBtn = document.getElementById('purge-cache-btn');
    const purgeStatus = document.getElementById('purge-status');
    const lastPurgeTime = document.getElementById('lastPurgeTime');
    const refreshBtn = document.getElementById('refresh-status-btn');
    const toggleField = document.getElementById('accelerator-toggle-field');

    // Enable/Disable Toggle (only exists if isReady)
    if (toggleField) {
        const $toggle = $('#accelerator-toggle');

        $toggle.on('change', function() {
            // Small delay to let the UI update first
            setTimeout(function() {
                const enabled = $toggle.find('button').attr('aria-checked') === 'true';

                Craft.sendActionRequest('POST', 'algolia-accelerator/cache/toggle', {
                    data: { enabled: enabled }
                })
                .then(response => {
                    if (response.data.success) {
                        Craft.cp.displayNotice(enabled ? 'Auto-purge enabled' : 'Auto-purge disabled');
                    } else {
                        Craft.cp.displayError(response.data.message || 'Failed to update setting');
                        window.location.reload();
                    }
                })
                .catch(error => {
                    Craft.cp.displayError('Failed to update setting');
                    window.location.reload();
                });
            }, 100);
        });
    }

    // Purge Button
    if (purgeBtn) {
        purgeBtn.addEventListener('click', function() {
            if (this.classList.contains('disabled')) return;

            this.classList.add('loading');
            purgeStatus.textContent = '';

            Craft.sendActionRequest('POST', 'algolia-accelerator/cache/purge')
                .then(response => {
                    purgeBtn.classList.remove('loading');
                    if (response.data.success) {
                        purgeStatus.textContent = response.data.message;
                        purgeStatus.style.color = 'green';
                        lastPurgeTime.textContent = new Date().toLocaleString();
                    } else {
                        purgeStatus.textContent = response.data.message;
                        purgeStatus.style.color = 'red';
                    }
                })
                .catch(error => {
                    purgeBtn.classList.remove('loading');
                    purgeStatus.textContent = 'Error: ' + (error.message || 'Unknown error');
                    purgeStatus.style.color = 'red';
                });
        });
    }

    // Refresh Status Button
    if (refreshBtn) {
        refreshBtn.addEventListener('click', function() {
            this.classList.add('loading');
            window.location.reload();
        });
    }
})();
{% endjs %}
